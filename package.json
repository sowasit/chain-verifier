{
  "name": "@sowasit/chain-verifier",
  "version": "0.1.2",
  "description": "Cryptographic verification tool for SoWasIt blockchain chains - verify chain integrity offline",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sowasit-verify": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "verify": "node dist/cli.js"
  },
  "keywords": [
    "blockchain",
    "verification",
    "cryptography",
    "integrity",
    "chain",
    "hash",
    "sowasit"
  ],
  "author": "SoWasIt",
  "license": "MIT",
  "files": [
    "dist",
    "!dist/__tests__",
    "!.sowasit-cache",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "json-stringify-deterministic": "^1.0.12",
    "stream-json": "^1.9.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/node": "^20.10.6",
    "@types/stream-json": "^1.7.8",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sowasit/chain-verifier"
  },
  "bugs": {
    "url": "https://github.com/sowasit/chain-verifier/issues"
  },
  "homepage": "https://sowasit.io"
}
